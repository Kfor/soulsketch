# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM via OpenRouter (OpenAI-compatible format)
# Also used for content moderation (LLM-based classifier)
OPENROUTER_API_KEY=your-openrouter-api-key
AI_LLM_MODEL=gpt-4o

# Image Generation via FAL
FAL_KEY=your-fal-key

# Rate Limiting
RATE_LIMIT_ANON_GENERATIONS=5
RATE_LIMIT_WINDOW_MS=86400000

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (created by scripts/stripe-provision.sh)
# Test mode defaults for this project:
STRIPE_PRICE_EXPORT_HD=price_1T1qg2ANb9PN7Uxv0o8a69Ds
STRIPE_PRICE_PLUS_MONTHLY=price_1T1qgKANb9PN7Uxv5IxIEDGL

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
