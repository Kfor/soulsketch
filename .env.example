# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Image Generation (e.g., DALL-E, Stability AI, Replicate)
AI_IMAGE_API_KEY=your-image-api-key
AI_IMAGE_API_URL=https://api.openai.com/v1/images/generations

# AI Chat / LLM (e.g., OpenAI, Anthropic)
AI_LLM_API_KEY=your-llm-api-key
AI_LLM_API_URL=https://api.openai.com/v1/chat/completions
AI_LLM_MODEL=gpt-4o

# Rate Limiting
RATE_LIMIT_ANON_GENERATIONS=5
RATE_LIMIT_WINDOW_MS=86400000

# Content Moderation
MODERATION_API_KEY=your-moderation-api-key

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (created by scripts/stripe-provision.sh)
# Test mode defaults for this project:
STRIPE_PRICE_EXPORT_HD=price_1T1qg2ANb9PN7Uxv0o8a69Ds
STRIPE_PRICE_PLUS_MONTHLY=price_1T1qgKANb9PN7Uxv5IxIEDGL

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
